# ============================================================
# TransitIQ — Environment Variables Template
# ------------------------------------------------------------
# STEP 1: Copy this file and rename the copy to .env
# STEP 2: Fill in your real values in .env
# STEP 3: NEVER commit .env to Git (it's in .gitignore)
# ============================================================


# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transitiq
DB_USER=transitiq
DB_PASSWORD=localdev123
DATABASE_URL=postgresql://transitiq:localdev123@localhost:5432/transitiq


# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_STREAM_NAME=transit:events


# ── TTC (No API key needed — 100% public feed) ───────────────
TTC_VEHICLE_POSITIONS_URL=https://gtfsrt.ttc.ca/vehicles/position?format=binary
TTC_TRIP_UPDATES_URL=https://gtfsrt.ttc.ca/trips/update?format=binary
TTC_ALERTS_URL=https://gtfsrt.ttc.ca/alerts/all?format=binary


# ── GO Transit (Free key — register at api.openmetrolinx.com) 
GO_TRANSIT_API_KEY=your_go_transit_api_key_here
GO_TRIP_UPDATES_URL=https://api.openmetrolinx.com/OpenDataAPI/api/V1/GTFSRealTime/TripUpdate


# ── Weather (Open-Meteo — no key needed) ─────────────────────
WEATHER_TORONTO_URL=https://api.open-meteo.com/v1/forecast?latitude=43.7001&longitude=-79.4163&current=temperature_2m,precipitation,weathercode,windspeed_10m,relativehumidity_2m&timezone=America%2FToronto



# ── Ticketmaster (Free — register at developer.ticketmaster.com)
TICKETMASTER_API_KEY=your_ticketmaster_key_here


# ── Polling Intervals ────────────────────────────────────────
GTFS_POLL_INTERVAL_SECONDS=60
WEATHER_POLL_INTERVAL_SECONDS=3600


# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

CLERK_PUBLISHABLE_KEY=pk_test_Y29uY2lzZS1kb2xwaGluLTYuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=sk_test_hy7CHzkZHT3DB9bnry8lBRtrVlH5eBO5xd7Kfhz7IJ

VITE_API_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=pk_test_Y29uY2lzZS1kb2xwaGluLTYuY2xlcmsuYWNjb3VudHMuZGV2JA