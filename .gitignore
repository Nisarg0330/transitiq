# ============================================================
# TransitIQ — .gitignore
# ============================================================


# ── Environment Variables (NEVER commit these) ───────────────
.env
*.env.local
.env.production


# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
*.pyc
*.pyo
.Python
pip-log.txt


# ── Node.js ──────────────────────────────────────────────────
node_modules/
dist/
build/
.next/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ── ML Models (too large for Git) ────────────────────────────

*.joblib
*.model
*.h5
models/saved/


# ── Docker volumes (local data only) ─────────────────────────
data/
postgres_data/
redis_data/


# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
*.log.*


# ── Jupyter Notebooks checkpoints ────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints


# ── VS Code ──────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
*.code-workspace


# ── Operating System ─────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini


# ── Testing & Coverage ───────────────────────────────────────
coverage/
.coverage
htmlcov/
.nyc_output/


# ── Temporary files ──────────────────────────────────────────
*.tmp
*.temp
*.swp
*.swo
